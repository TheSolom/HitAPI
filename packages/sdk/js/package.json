{
    "name": "@hitapi/js",
    "version": "1.0.0",
    "description": "HitAPI JavaScript SDK",
    "author": "TheSolom",
    "license": "MIT",
    "homepage": "https://github.com/TheSolom/HitAPI#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/TheSolom/HitAPI.git"
    },
    "bugs": {
        "url": "https://github.com/TheSolom/HitAPI/issues"
    },
    "type": "module",
    "files": [
        "dist"
    ],
    "exports": {
        "./express": "./dist/integrations/express/index.js"
    },
    "scripts": {
        "build": "tsc",
        "format": "prettier --write \"src/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.ts\"",
        "start": "node dist/index.js",
        "start:dev": "tsc -w",
        "lint": "eslint \"{src,test}/**/*.ts\"",
        "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
        "test": "node --experimental-vm-modules ../../../node_modules/jest/bin/jest.js",
        "test:watch": "node --experimental-vm-modules ../../../node_modules/jest/bin/jest.js --watch",
        "test:cov": "node --experimental-vm-modules ../../../node_modules/jest/bin/jest.js --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register ../../../node_modules/.bin/jest --runInBand"
    },
    "keywords": [
        "hitapi",
        "sdk",
        "js",
        "express"
    ],
    "peerDependencies": {
        "express": "^4 || ^5",
        "pino": "^8 || ^9 || ^10"
    },
    "peerDependenciesMeta": {
        "express": {
            "optional": true
        },
        "pino": {
            "optional": true
        }
    },
    "dependencies": {
        "@hitapi/shared": "^1.0.0",
        "@hitapi/types": "^1.0.0",
        "async-lock": "^1.4.1",
        "denque": "^2.1.0",
        "fetch-retry": "^6.0.0",
        "http-status-codes": "^2.3.0",
        "request-ip": "^3.3.0",
        "winston": "^3.19.0"
    },
    "devDependencies": {
        "@nestjs/common": "^11.1.16",
        "@types/async-lock": "^1.4.2",
        "@types/request-ip": "^0.0.41",
        "express": "^4 || ^5",
        "express-validator": "^7.1.0",
        "nock": "^14.0.11",
        "pino-http": "^11.0.0"
    },
    "lint-staged": {
        "*.ts": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,yml,yaml}": [
            "prettier --write"
        ]
    }
}
